---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const regions = [
  {
    name: 'East Asia',
    color: 'ocean',
    destinations: [
      { port: 'Shanghai', country: 'China', transit: '18-22 days' },
      { port: 'Ningbo', country: 'China', transit: '18-22 days' },
      { port: 'Shenzhen', country: 'China', transit: '16-20 days' },
      { port: 'Busan', country: 'South Korea', transit: '22-26 days' },
      { port: 'Tokyo', country: 'Japan', transit: '24-28 days' },
    ],
  },
  {
    name: 'Middle Asia (CIS)',
    color: 'teal',
    destinations: [
      { port: 'Bandar Abbas', country: 'Iran', transit: '2-4 days' },
      { port: 'Aktau', country: 'Kazakhstan', transit: '5-7 days' },
      { port: 'Turkmenbashi', country: 'Turkmenistan', transit: '5-7 days' },
      { port: 'Baku', country: 'Azerbaijan', transit: '4-6 days' },
      { port: 'Novorossiysk', country: 'Russia', transit: '6-8 days' },
    ],
  },
  {
    name: 'West Asia / South Asia',
    color: 'ocean',
    destinations: [
      { port: 'Mumbai', country: 'India', transit: '10-14 days' },
      { port: 'Nhava Sheva', country: 'India', transit: '10-14 days' },
      { port: 'Karachi', country: 'Pakistan', transit: '6-8 days' },
      { port: 'Colombo', country: 'Sri Lanka', transit: '8-10 days' },
      { port: 'Chittagong', country: 'Bangladesh', transit: '10-12 days' },
    ],
  },
  {
    name: 'Middle East',
    color: 'teal',
    destinations: [
      { port: 'Dubai (Jebel Ali)', country: 'UAE', transit: '6-8 days' },
      { port: 'Jeddah', country: 'Saudi Arabia', transit: '4-6 days' },
      { port: 'Doha', country: 'Qatar', transit: '5-7 days' },
      { port: 'Muscat', country: 'Oman', transit: '5-7 days' },
      { port: 'Kuwait', country: 'Kuwait', transit: '7-9 days' },
    ],
  },
  {
    name: 'Europe',
    color: 'ocean',
    destinations: [
      { port: 'Rotterdam', country: 'Netherlands', transit: '10-14 days' },
      { port: 'Antwerp', country: 'Belgium', transit: '10-14 days' },
      { port: 'Barcelona', country: 'Spain', transit: '8-12 days' },
      { port: 'Genoa', country: 'Italy', transit: '8-12 days' },
      { port: 'Constanta', country: 'Romania', transit: '6-8 days' },
      { port: 'Haydar Pasha', country: 'Turkey', transit: '3-5 days' },
    ],
  },
  {
    name: 'North & West Africa',
    color: 'teal',
    destinations: [
      { port: 'Tangier', country: 'Morocco', transit: '3-5 days' },
      { port: 'Casablanca', country: 'Morocco', transit: '4-6 days' },
      { port: 'Lagos', country: 'Nigeria', transit: '8-12 days' },
      { port: 'Tema', country: 'Ghana', transit: '8-10 days' },
      { port: 'Dakar', country: 'Senegal', transit: '6-8 days' },
    ],
  },
];
---

<Layout title="Routes & Network — FARCO Marine" description="Explore FARCO Marine's global shipping network. Sea freight routes across Asia, Europe, and Africa.">
  <Header slot="header" />
  <Footer slot="footer" />

  <PageHero title="Global Network" subtitle="Connecting you to major ports across Asia, Europe, and Africa" />

  <section class="section-padding bg-navy-900">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 mb-12 sm:mb-16 max-w-3xl mx-auto">
        <div class="text-center animate-on-scroll">
          <div class="text-2xl sm:text-3xl font-bold text-heading mb-1">50+</div>
          <div class="text-muted text-xs sm:text-sm">Destinations</div>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="text-2xl sm:text-3xl font-bold text-heading mb-1">25+</div>
          <div class="text-muted text-xs sm:text-sm">Countries</div>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="text-2xl sm:text-3xl font-bold text-heading mb-1">20+</div>
          <div class="text-muted text-xs sm:text-sm">Regular Routes</div>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="text-2xl sm:text-3xl font-bold text-heading mb-1">60+</div>
          <div class="text-muted text-xs sm:text-sm">Port Connections</div>
        </div>
      </div>

      <div class="mb-16 animate-on-scroll">
        <div class="max-w-5xl mx-auto bg-navy-800/30 rounded-2xl border border-navy-600/30 p-8 sm:p-12">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6 text-center">
            <div class="space-y-2">
              <div class="w-12 h-12 bg-ocean-500/10 rounded-full flex items-center justify-center mx-auto border-2 border-ocean-500/30">
                <svg class="w-5 h-5 text-ocean-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <div class="text-heading font-semibold text-sm">East Asia</div>
              <div class="text-muted text-xs">China, Korea, Japan</div>
            </div>
            <div class="space-y-2">
              <div class="w-12 h-12 bg-ocean-500/10 rounded-full flex items-center justify-center mx-auto border-2 border-ocean-500/30">
                <svg class="w-5 h-5 text-ocean-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <div class="text-heading font-semibold text-sm">Middle East</div>
              <div class="text-muted text-xs">UAE, Saudi, Qatar</div>
            </div>
            <div class="space-y-2">
              <div class="w-12 h-12 bg-ocean-500/10 rounded-full flex items-center justify-center mx-auto border-2 border-ocean-500/30">
                <svg class="w-5 h-5 text-ocean-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <div class="text-heading font-semibold text-sm">West Asia</div>
              <div class="text-muted text-xs">India, Pakistan</div>
            </div>
            <div class="space-y-2">
              <div class="w-12 h-12 bg-teal-500/10 rounded-full flex items-center justify-center mx-auto border-2 border-teal-500/30">
                <svg class="w-5 h-5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <div class="text-heading font-semibold text-sm">Europe</div>
              <div class="text-muted text-xs">NL, BE, ES, IT, RO, TR</div>
            </div>
            <div class="space-y-2 col-span-2 sm:col-span-1">
              <div class="w-12 h-12 bg-ocean-500/10 rounded-full flex items-center justify-center mx-auto border-2 border-ocean-500/30">
                <svg class="w-5 h-5 text-ocean-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <div class="text-heading font-semibold text-sm">Africa</div>
              <div class="text-muted text-xs">Morocco, Nigeria, Kenya</div>
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-navy-600/20 text-center">
            <p class="text-muted text-sm">Connecting <span class="text-ocean-400 font-semibold">30+ countries</span> through our extensive maritime network</p>
          </div>
        </div>
      </div>

      <div class="space-y-10">
        {regions.map((region) => (
          <div class="animate-on-scroll">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-2 h-8 bg-ocean-500 rounded-full"></div>
              <h3 class="text-2xl font-bold text-heading">{region.name}</h3>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
              {region.destinations.map((dest) => (
                <div class="bg-navy-800/30 border border-navy-600/20 rounded-xl p-4 hover:border-ocean-500/30 transition-all duration-300 hover:-translate-y-0.5">
                  <div class="text-heading font-medium text-sm mb-1">{dest.port}</div>
                  <div class="text-faint text-xs mb-2">{dest.country}</div>
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-ocean-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span class="text-ocean-400 text-xs font-medium">{dest.transit}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center animate-on-scroll">
        <p class="text-muted mb-4">Don't see your destination? We likely cover it.</p>
        <a href="/quote" class="btn-primary">
          Request a Route Quote
        </a>
      </div>
    </div>
  </section>

  <CTABanner title="Need a Custom Route?" subtitle="Our team can arrange shipping to virtually any port in the world. Get in touch for a tailored solution." buttonText="Contact Us" buttonHref="/contact" />
</Layout>
