---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const regions = [
  {
    name: 'Asia Pacific',
    color: 'ocean',
    destinations: [
      { port: 'Shanghai', country: 'China', transit: '18-22 days' },
      { port: 'Singapore', country: 'Singapore', transit: '12-15 days' },
      { port: 'Hong Kong', country: 'China', transit: '20-24 days' },
      { port: 'Busan', country: 'South Korea', transit: '22-26 days' },
      { port: 'Mumbai', country: 'India', transit: '10-14 days' },
    ],
  },
  {
    name: 'Middle East',
    color: 'teal',
    destinations: [
      { port: 'Dubai (Jebel Ali)', country: 'UAE', transit: '6-8 days' },
      { port: 'Jeddah', country: 'Saudi Arabia', transit: '4-6 days' },
      { port: 'Doha', country: 'Qatar', transit: '5-7 days' },
      { port: 'Muscat', country: 'Oman', transit: '5-7 days' },
      { port: 'Kuwait', country: 'Kuwait', transit: '7-9 days' },
    ],
  },
  {
    name: 'Europe',
    color: 'ocean',
    destinations: [
      { port: 'Rotterdam', country: 'Netherlands', transit: '10-14 days' },
      { port: 'Hamburg', country: 'Germany', transit: '12-16 days' },
      { port: 'Felixstowe', country: 'United Kingdom', transit: '10-14 days' },
      { port: 'Piraeus', country: 'Greece', transit: '6-8 days' },
      { port: 'Marseille', country: 'France', transit: '8-12 days' },
    ],
  },
  {
    name: 'Americas',
    color: 'teal',
    destinations: [
      { port: 'New York / New Jersey', country: 'USA', transit: '16-20 days' },
      { port: 'Los Angeles', country: 'USA', transit: '22-28 days' },
      { port: 'Santos', country: 'Brazil', transit: '14-18 days' },
      { port: 'Cartagena', country: 'Colombia', transit: '12-16 days' },
      { port: 'Veracruz', country: 'Mexico', transit: '14-18 days' },
    ],
  },
  {
    name: 'Africa',
    color: 'ocean',
    destinations: [
      { port: 'Durban', country: 'South Africa', transit: '10-14 days' },
      { port: 'Mombasa', country: 'Kenya', transit: '6-8 days' },
      { port: 'Lagos', country: 'Nigeria', transit: '8-12 days' },
      { port: 'Tangier', country: 'Morocco', transit: '3-5 days' },
      { port: 'Djibouti', country: 'Djibouti', transit: '4-6 days' },
    ],
  },
];
---

<Layout title="Routes & Network — FARCO Marine" description="Explore FARCO Marine's global shipping network. Sea freight routes across Asia Pacific, Middle East, Europe, Americas, and Africa.">
  <Header slot="header" />
  <Footer slot="footer" />

  <PageHero title="Global Network" subtitle="Connecting you to major ports across every continent" />

  <section class="section-padding bg-navy-900">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16 max-w-3xl mx-auto">
        <div class="text-center animate-on-scroll">
          <div class="text-3xl font-bold text-white mb-1">50+</div>
          <div class="text-slate-400 text-sm">Destinations</div>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="text-3xl font-bold text-white mb-1">30+</div>
          <div class="text-slate-400 text-sm">Countries</div>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="text-3xl font-bold text-white mb-1">25+</div>
          <div class="text-slate-400 text-sm">Regular Routes</div>
        </div>
        <div class="text-center animate-on-scroll">
          <div class="text-3xl font-bold text-white mb-1">100+</div>
          <div class="text-slate-400 text-sm">Port Connections</div>
        </div>
      </div>

      <div class="relative mb-16 animate-on-scroll">
        <div class="aspect-[16/7] max-w-5xl mx-auto bg-navy-800/50 rounded-2xl border border-navy-600/30 overflow-hidden relative">
          <svg class="w-full h-full" viewBox="0 0 1000 440" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="1000" height="440" fill="transparent"/>
            
            <path d="M160 180 Q 300 160, 420 200 Q 540 240, 680 190 Q 820 140, 880 180" stroke="rgba(14, 165, 233, 0.2)" stroke-width="2" stroke-dasharray="8 4" fill="none"/>
            <path d="M160 220 Q 300 260, 420 240 Q 540 220, 680 250 Q 820 280, 880 230" stroke="rgba(6, 182, 212, 0.2)" stroke-width="2" stroke-dasharray="8 4" fill="none"/>
            <path d="M500 320 Q 600 300, 700 310 Q 800 320, 850 340" stroke="rgba(14, 165, 233, 0.15)" stroke-width="2" stroke-dasharray="6 4" fill="none"/>
            
            {[
              { x: 780, y: 130, label: 'Asia', active: true },
              { x: 520, y: 180, label: 'Middle East', active: true },
              { x: 480, y: 110, label: 'Europe', active: true },
              { x: 230, y: 140, label: 'Americas', active: true },
              { x: 490, y: 310, label: 'Africa', active: true },
            ].map((point) => (
              <g>
                <circle cx={point.x} cy={point.y} r="20" fill={point.active ? 'rgba(14, 165, 233, 0.1)' : 'rgba(100, 116, 139, 0.1)'}/>
                <circle cx={point.x} cy={point.y} r="6" fill={point.active ? '#0EA5E9' : '#64748B'}/>
                <circle cx={point.x} cy={point.y} r="6" fill={point.active ? '#0EA5E9' : '#64748B'}>
                  <animate attributeName="r" values="6;12;6" dur="3s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="1;0.3;1" dur="3s" repeatCount="indefinite"/>
                </circle>
                <text x={point.x} y={point.y - 28} text-anchor="middle" fill={point.active ? '#38BDF8' : '#94A3B8'} font-size="12" font-weight="500">{point.label}</text>
              </g>
            ))}
          </svg>
        </div>
      </div>

      <div class="space-y-10">
        {regions.map((region) => (
          <div class="animate-on-scroll">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-2 h-8 bg-ocean-500 rounded-full"></div>
              <h3 class="text-2xl font-bold text-white">{region.name}</h3>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
              {region.destinations.map((dest) => (
                <div class="bg-navy-800/30 border border-navy-600/20 rounded-xl p-4 hover:border-ocean-500/30 transition-all duration-300 hover:-translate-y-0.5">
                  <div class="text-white font-medium text-sm mb-1">{dest.port}</div>
                  <div class="text-slate-500 text-xs mb-2">{dest.country}</div>
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-ocean-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    <span class="text-ocean-400 text-xs font-medium">{dest.transit}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 text-center animate-on-scroll">
        <p class="text-slate-400 mb-4">Don't see your destination? We likely cover it.</p>
        <a href="/quote" class="btn-primary">
          Request a Route Quote
        </a>
      </div>
    </div>
  </section>

  <CTABanner title="Need a Custom Route?" subtitle="Our team can arrange shipping to virtually any port in the world. Get in touch for a tailored solution." buttonText="Contact Us" buttonHref="/contact" />
</Layout>
