---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Us — FARCO Marine" description="Get in touch with FARCO Marine. Contact us for sea freight quotes, logistics inquiries, and partnership opportunities.">
  <Header slot="header" />
  <Footer slot="footer" />

  <PageHero title="Get in Touch" subtitle="We'd love to hear from you. Reach out for quotes, questions, or partnerships." />

  <section class="section-padding bg-navy-900">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
          <form action="mailto:info@farcomarine.net" method="POST" enctype="text/plain" class="card animate-on-scroll">
            <h3 class="text-xl font-semibold text-heading mb-6">Send Us a Message</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <label class="block text-body text-sm font-medium mb-2">Full Name *</label>
                <input type="text" name="name" required placeholder="Your name" class="input-field" />
              </div>
              <div>
                <label class="block text-body text-sm font-medium mb-2">Email Address *</label>
                <input type="email" name="email" required placeholder="your@email.com" class="input-field" />
              </div>
            </div>
            <div class="mb-4">
              <label class="block text-body text-sm font-medium mb-2">Subject</label>
              <select name="subject" class="input-field">
                <option value="">Select a topic</option>
                <option value="quote">Quote Request</option>
                <option value="shipment">Shipment Inquiry</option>
                <option value="partnership">Partnership Opportunity</option>
                <option value="careers">Careers</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="mb-6">
              <label class="block text-body text-sm font-medium mb-2">Message *</label>
              <textarea name="message" required rows="6" placeholder="How can we help you?" class="input-field resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary">
              Send Message
            </button>
          </form>
        </div>

        <div class="lg:col-span-1">
          <div class="space-y-6">
            <div class="card animate-on-scroll">
              <h3 class="text-heading font-semibold mb-5">Contact Details</h3>
              <div class="space-y-5">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-ocean-500/10 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-ocean-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-heading font-medium text-sm mb-1">Office Address</div>
                    <div class="text-muted text-sm">Contact us for our office address</div>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-ocean-500/10 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-ocean-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-heading font-medium text-sm mb-1">Phone</div>
                    <a href="tel:+0000000000" class="text-muted text-sm hover:text-ocean-400 transition-colors">Contact us for phone number</a>
                  </div>
                </div>

                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-ocean-500/10 rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-ocean-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-heading font-medium text-sm mb-1">Email</div>
                    <a href="mailto:info@farcomarine.net" class="text-muted text-sm hover:text-ocean-400 transition-colors">info@farcomarine.net</a>
                  </div>
                </div>
              </div>
            </div>

            <div class="card animate-on-scroll">
              <h3 class="text-heading font-semibold mb-4">Business Hours</h3>
              <div class="space-y-3">
                {[
                  { day: 'Monday - Friday', hours: '08:00 - 18:00' },
                  { day: 'Saturday', hours: '09:00 - 14:00' },
                  { day: 'Sunday', hours: 'Closed' },
                ].map((schedule) => (
                  <div class="flex justify-between items-center">
                    <span class="text-body text-sm">{schedule.day}</span>
                    <span class:list={[
                      'text-sm font-medium',
                      schedule.hours === 'Closed' ? 'text-faint' : 'text-ocean-400',
                    ]}>
                      {schedule.hours}
                    </span>
                  </div>
                ))}
              </div>
            </div>

            <div class="card animate-on-scroll bg-gradient-to-br from-ocean-600/20 to-teal-500/10 border-ocean-500/20">
              <h3 class="text-heading font-semibold mb-2">Emergency Shipping?</h3>
              <p class="text-muted text-sm mb-4">For urgent shipments outside business hours, reach out via email and mark it as urgent.</p>
              <a href="mailto:info@farcomarine.net?subject=URGENT Shipping Request" class="btn-outline text-xs w-full text-center">
                Send Urgent Request
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
