---
export interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  highlighted?: boolean;
}
const { icon, title, description, href, highlighted = false } = Astro.props;
---

<div class:list={['card-hover group', highlighted && 'md:col-span-2 lg:col-span-1 border-ocean-500/20']}>
  <div class:list={[
    'w-12 h-12 rounded-xl flex items-center justify-center mb-4 transition-colors duration-300',
    highlighted 
      ? 'bg-ocean-500 text-navy-900' 
      : 'bg-navy-700/50 text-ocean-400 group-hover:bg-ocean-500 group-hover:text-navy-900'
  ]}>
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-white font-semibold text-lg mb-2">{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed mb-4">{description}</p>
  {href && (
    <a href={href} class="inline-flex items-center gap-1.5 text-ocean-400 text-sm font-medium group-hover:text-ocean-300 transition-colors">
      Learn more
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  )}
</div>
