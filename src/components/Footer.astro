---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About Us' },
  { href: '/services', label: 'Services' },
  { href: '/routes', label: 'Routes' },
  { href: '/quote', label: 'Get a Quote' },
  { href: '/contact', label: 'Contact' },
];

const services = [
  'Sea Freight',
  'Road Transport',
  'Customs Clearance',
  'Warehousing',
  'Cargo Insurance',
  'Supply Chain Solutions',
];
---

<footer class="bg-navy-950 border-t border-navy-700/30">
  <div class="container-custom py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-ocean-500 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-navy-900" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1s1.2 1 2.5 1c2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1" />
              <path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76" />
              <path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6" />
              <path d="M12 3v4" />
            </svg>
          </div>
          <div>
            <span class="text-xl font-bold text-heading tracking-tight">FARCO</span>
            <span class="text-xs block text-ocean-400 tracking-widest uppercase -mt-1">Marine</span>
          </div>
        </a>
        <p class="text-muted text-sm leading-relaxed mb-6">
          Your trusted partner in sea freight and global logistics. Delivering reliability across the world's oceans since day one.
        </p>
        <div class="flex gap-3">
          <a href="#" class="w-9 h-9 bg-navy-800 hover:bg-ocean-500 rounded-lg flex items-center justify-center transition-all duration-300 group" aria-label="LinkedIn">
            <svg class="w-4 h-4 text-muted group-hover:text-navy-900 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="w-9 h-9 bg-navy-800 hover:bg-ocean-500 rounded-lg flex items-center justify-center transition-all duration-300 group" aria-label="Facebook">
            <svg class="w-4 h-4 text-muted group-hover:text-navy-900 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="mailto:info@farcomarine.net" class="w-9 h-9 bg-navy-800 hover:bg-ocean-500 rounded-lg flex items-center justify-center transition-all duration-300 group" aria-label="Email">
            <svg class="w-4 h-4 text-muted group-hover:text-navy-900 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-heading font-semibold text-sm uppercase tracking-wider mb-5">Quick Links</h3>
        <ul class="space-y-1">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="block py-2 text-muted hover:text-ocean-400 text-sm transition-colors duration-300">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-heading font-semibold text-sm uppercase tracking-wider mb-5">Services</h3>
        <ul class="space-y-1">
          {services.map((service) => (
            <li>
              <a href="/services" class="block py-2 text-muted hover:text-ocean-400 text-sm transition-colors duration-300">
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-heading font-semibold text-sm uppercase tracking-wider mb-5">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-ocean-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span class="text-muted text-sm">FARCO Marine Headquarters<br />Contact us for address details</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a href="tel:+0000000000" class="text-muted hover:text-ocean-400 text-sm transition-colors">Contact us for phone</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:info@farcomarine.net" class="text-muted hover:text-ocean-400 text-sm transition-colors">info@farcomarine.net</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-ocean-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-muted text-sm">Mon - Fri: 08:00 - 18:00</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-navy-700/30">
    <div class="container-custom py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-faint text-sm">
        &copy; {currentYear} FARCO Marine. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy-policy" class="text-faint hover:text-muted text-sm transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="text-faint hover:text-muted text-sm transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
