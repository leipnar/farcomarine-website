---
export interface Props {
  icon: string;
  title: string;
  description: string;
}
const { icon, title, description } = Astro.props;
---

<div class="flex items-start gap-4 group">
  <div class="w-10 h-10 rounded-lg bg-ocean-500/10 border border-ocean-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-ocean-500 group-hover:border-ocean-500 transition-all duration-300">
    <span class="text-ocean-400 group-hover:text-navy-900 transition-colors" set:html={icon} />
  </div>
  <div>
    <h3 class="text-white font-semibold mb-1">{title}</h3>
    <p class="text-slate-400 text-sm leading-relaxed">{description}</p>
  </div>
</div>
